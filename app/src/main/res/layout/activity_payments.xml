<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"


    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#fff"
    android:backgroundTint="#fff"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Payments">


    <ImageView
        android:layout_width="320dp"
        android:layout_marginLeft="40dp"

        android:layout_marginTop="1dp"
        android:paddingTop="100dp"
        android:layout_height="300dp"
        android:id="@+id/product_photo"
        android:src="@drawable/splash"

        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product name"
        android:textColor="#24C3B8"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="30dp"
        android:id="@+id/product_name"

        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ksh 100"
        android:id="@+id/product_cost"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="10dp"
        android:textColor="#297A3A"

        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="this is acup cake"
        android:layout_marginLeft="40dp"
        android:textColor="@color/black"
        android:layout_marginRight="40dp"
        android:id="@+id/product_description"

        />


    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="40dp"
        android:layout_marginRight="50dp"
        android:textColor="@color/black"
        android:textColorHint="#f3ff"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:hint="Enter phone 254xxxxxxxxx"
        android:background="@drawable/edittext"
        android:padding="14dp"
        android:layout_marginTop="16dp"
        android:id="@+id/phone"

        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="44dp"
        android:layout_marginRight="44dp"
        android:layout_marginTop="30dp"
        android:backgroundTint="#40d2de"
        android:textColor="@color/white"
        android:textAlignment="center"
        android:id="@+id/purchase"
        android:text="Checkout"

        />




</LinearLayout>